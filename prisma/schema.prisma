generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(SUPERVISOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supervisor {
  id        String     @id @default(cuid())
  name      String
  email     String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  promoters Promoter[]
}

model Promoter {
  id           String     @id @default(cuid())
  name         String
  city         String?
  state        String?
  supervisorId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id])
  visits       Visit[]
}

model Industry {
  id        String          @id @default(cuid())
  code      String          @unique
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  visits    Visit[]
  aliases   IndustryAlias[]
  evidences VisitEvidence[]
}

model Store {
  id        String          @id @default(cuid())
  code      String          @unique
  name      String
  chain     String?
  city      String?
  state     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  visits    Visit[]
  aliases   StoreAlias[]
  evidences VisitEvidence[]
}

model Visit {
  id            String          @id @default(cuid())
  promoterId    String
  storeId       String
  industryId    String
  status        VisitStatus     @default(PLANEJADA)
  scheduledDate DateTime
  completedDate DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  operationId   String
  industry      Industry        @relation(fields: [industryId], references: [id])
  operation     Operation       @relation(fields: [operationId], references: [id])
  promoter      Promoter        @relation(fields: [promoterId], references: [id])
  store         Store           @relation(fields: [storeId], references: [id])
  evidences     VisitEvidence[]
}

model Operation {
  id           String          @id @default(cuid())
  name         String
  month        Int
  year         Int
  status       OperationStatus @default(PLANNING)
  startsAt     DateTime
  endsAt       DateTime
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  clientId     String?
  description  String?
  observations String?
  visits       Visit[]
  imports      Import[]
  evidences    VisitEvidence[]

  @@unique([month, year])
}

model Import {
  id               String                  @id @default(cuid())
  status           String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  files            ImportFile[]
  previewArtifacts ImportPreviewArtifact[]
  confirmations    ImportConfirmation[]
  operationId      String?
  operation        Operation?              @relation(fields: [operationId], references: [id], onDelete: SetNull)
  visitEvidences   VisitEvidence[]

  @@index([operationId])
}

model StoreAlias {
  id        String   @id @default(cuid())
  aliasKey  String   @unique
  alias     String
  storeId   String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model IndustryAlias {
  id         String   @id @default(cuid())
  aliasKey   String   @unique
  alias      String
  industryId String
  createdAt  DateTime @default(now())
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@index([industryId])
}

model VisitEvidence {
  id               String                @id @default(cuid())
  importId         String
  operationId      String
  visitId          String?
  storeId          String?
  industryId       String?
  evidenceDate     DateTime
  sourceFile       String
  sourceSheet      String?
  sourceRow        Int?
  rawStoreName     String
  rawIndustryName  String
  rawBrand         String?
  rawCity          String?
  rawState         String?
  suggestion       Json?
  diagnostics      Json?
  deduplicationKey String                @unique
  result           ReconciliationResult
  confidence       Int                   @default(0)
  reviewedAt       DateTime?
  reviewedBy       String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  import           Import                @relation(fields: [importId], references: [id], onDelete: Cascade)
  operation        Operation             @relation(fields: [operationId], references: [id], onDelete: Cascade)
  visit            Visit?                @relation(fields: [visitId], references: [id], onDelete: SetNull)
  store            Store?                @relation(fields: [storeId], references: [id], onDelete: SetNull)
  industry         Industry?             @relation(fields: [industryId], references: [id], onDelete: SetNull)
  audits           ReconciliationAudit[]

  @@index([operationId, evidenceDate])
  @@index([visitId])
  @@index([result])
}

model ReconciliationAudit {
  id         String        @id @default(cuid())
  evidenceId String
  action     String
  actor      String
  before     Json?
  after      Json?
  createdAt  DateTime      @default(now())
  evidence   VisitEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@index([evidenceId])
}

model ImportFile {
  id        String   @id @default(cuid())
  fileName  String
  fileHash  String   @unique
  rowCount  Int?
  importId  String
  createdAt DateTime @default(now())
  import    Import   @relation(fields: [importId], references: [id])
}

model ImportPreviewArtifact {
  id           String              @id @default(cuid())
  importId     String
  tokenHash    String              @unique
  fileHash     String
  dataDigest   String
  payload      Json
  acceptedRows Int
  rejectedRows Int
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime            @default(now())
  import       Import              @relation(fields: [importId], references: [id], onDelete: Cascade)
  confirmation ImportConfirmation?

  @@index([importId])
  @@index([expiresAt])
}

model ImportConfirmation {
  id                String                @id @default(cuid())
  importId          String
  previewArtifactId String                @unique
  idempotencyKey    String                @unique
  acceptedRows      Int
  rejectedRows      Int
  confirmedAt       DateTime              @default(now())
  createdAt         DateTime              @default(now())
  import            Import                @relation(fields: [importId], references: [id], onDelete: Cascade)
  previewArtifact   ImportPreviewArtifact @relation(fields: [previewArtifactId], references: [id], onDelete: Restrict)

  @@index([importId])
}

model SyncLog {
  id        String   @id @default(cuid())
  action    String
  status    String
  message   String
  details   Json?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  SUPERVISOR
}

enum VisitStatus {
  PLANEJADA
  REALIZADA
  CANCELADA
}

enum OperationStatus {
  PLANNING
  OPEN
  IN_PROGRESS
  FINISHED
  CANCELLED
  ARCHIVED
}

enum ReconciliationResult {
  MATCHED
  UNPLANNED
  AMBIGUOUS
  DATE_MISMATCH
  STORE_NOT_FOUND
  INDUSTRY_NOT_FOUND
  DUPLICATE_EVIDENCE
}
